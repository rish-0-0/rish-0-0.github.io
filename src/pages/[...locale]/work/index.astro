---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getCollection } from 'astro:content';
import ChatLayout from '../../../layouts/ChatLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { t, LOCALES, localeParam, DEFAULT_LOCALE } from '../../../i18n';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale: localeParam(locale) } }));
}

const locale = Astro.params.locale ?? DEFAULT_LOCALE;
const strings = t(locale);

// IDs: "en/work/this-portfolio.md" - strip locale + type + extension
const toSlug = (id: string) => id.split('/').slice(2).join('/').replace(/\.mdx?$/, '');

const allProjects = await getCollection('work');
const projects = allProjects
  .filter((p) => p.id.startsWith(locale + '/'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((p) => ({ ...p, slug: toSlug(p.id) }));
---

<ChatLayout title={strings.work.title} description={strings.work.description} locale={locale}>
  <div class="max-w-5xl p-6 sm:p-10">
    <header class="mb-9">
      <h1 class="font-heading text-3xl font-bold tracking-tight text-fg">{strings.work.title}</h1>
      <p class="mt-2 text-fg-muted">{strings.work.subtitle}</p>
    </header>

    {projects.length === 0 ? (
      <p class="italic text-fg-muted">{strings.work.empty}</p>
    ) : (
      <ul class="grid grid-cols-1 gap-5 md:grid-cols-2" role="list">
        {projects.map((project) => (
          <li>
            <PostCard
              href={getRelativeLocaleUrl(locale, 'work/' + project.slug)}
              title={project.data.title}
              description={project.data.description}
              pubDate={project.data.pubDate}
              tags={project.data.tags}
              shortDate
              liveUrl={project.data.url}
              locale={locale}
              liveSiteLabel={project.data.linkLabel ?? strings.work.liveSite}
            />
          </li>
        ))}
      </ul>
    )}
  </div>
</ChatLayout>
