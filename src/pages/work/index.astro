---
import { getCollection } from 'astro:content';
import ChatLayout from '../../layouts/ChatLayout.astro';
import PostCard from '../../components/PostCard.astro';

const projects = (await getCollection('work')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<ChatLayout title="Work" description="Selected projects and case studies.">
  <div class="max-w-3xl p-10">
    <header class="mb-9">
      <h1 class="font-heading text-3xl font-bold tracking-tight text-fg">Work</h1>
      <p class="mt-2 text-fg-muted">Selected projects - click any to read more.</p>
    </header>

    {projects.length === 0 ? (
      <p class="italic text-fg-muted">No projects yet - check back soon.</p>
    ) : (
      <ul class="flex flex-col gap-3" role="list">
        {projects.map((project) => (
          <li>
            <PostCard
              href={`/work/${project.id.replace(/\.mdx?$/, '')}`}
              title={project.data.title}
              description={project.data.description}
              pubDate={project.data.pubDate}
              tags={project.data.tags}
              shortDate
              liveUrl={project.data.url}
            />
          </li>
        ))}
      </ul>
    )}
  </div>
</ChatLayout>
