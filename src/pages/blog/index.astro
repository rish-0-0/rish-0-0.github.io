---
import { getCollection } from 'astro:content';
import ChatLayout from '../../layouts/ChatLayout.astro';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<ChatLayout title="Blog" description="Writing on design, engineering, and ideas.">
  <div class="max-w-3xl p-10">
    <header class="mb-9">
      <h1 class="font-heading text-3xl font-bold tracking-tight text-fg">Blog</h1>
      <p class="mt-2 text-fg-muted">Thoughts on design, engineering, and things in between.</p>
    </header>

    {posts.length === 0 ? (
      <p class="italic text-fg-muted">No posts yet - check back soon.</p>
    ) : (
      <ul class="flex flex-col gap-3" role="list">
        {posts.map((post) => (
          <li>
            <PostCard
              href={`/blog/${post.id.replace(/\.mdx?$/, '')}`}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
            />
          </li>
        ))}
      </ul>
    )}
  </div>
</ChatLayout>
