---
import ChatLayout from '../layouts/ChatLayout.astro';
import '../styles/prose.css';
---

<ChatLayout title="Contact" description="Get in touch.">
  <div class="prose">
    <h1>Contact</h1>
    <p>The best way to reach me is by email. I read everything.</p>

    <a
      href="mailto:rishabhanand42@gmail.com"
      class="mt-6 inline-flex items-center gap-2.5 rounded-xl border border-border bg-surface px-5 py-3.5 font-medium text-fg no-underline transition-all hover:border-accent hover:bg-surface-raised hover:shadow-[var(--shadow)]"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" class="text-accent shrink-0" aria-hidden="true">
        <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1zm13 2.383-4.708 2.825L15 11.105zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741M1 11.105l4.708-2.897L1 5.383z"/>
      </svg>
      rishabhanand42@gmail.com
    </a>

    <p class="mt-8 text-[0.9rem] text-fg-muted">Response time is usually within a day or two.</p>
  </div>
</ChatLayout>
