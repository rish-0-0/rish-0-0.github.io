---
import Base from './Base.astro';
import Sidebar from '../components/Sidebar.astro';
import ThemeSwitcher from '../components/ThemeSwitcher';
import '../styles/themes.scss';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<Base title={title} description={description}>
  <div class="flex h-dvh overflow-hidden">
    <Sidebar />

    <div class="flex flex-1 flex-col overflow-hidden bg-bg">
      <header class="h-[57px] flex items-center justify-end shrink-0 px-6 gap-2 border-b border-border">
        <button
          id="menu-toggle"
          class="menu-toggle hidden items-center justify-center p-1 rounded-md border-none bg-transparent text-fg-muted hover:text-fg hover:bg-surface transition-colors"
          aria-label="Open navigation"
          aria-expanded="false"
          aria-controls="sidebar"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
            <path d="M3 5h14M3 10h14M3 15h14"/>
          </svg>
        </button>

        <ThemeSwitcher client:load />
      </header>

      <main class="flex-1 overflow-y-auto" id="main-content" tabindex="-1">
        <slot />
      </main>
    </div>
  </div>
</Base>

<style>
  @media (max-width: 768px) {
    .menu-toggle { display: flex; }
    header { justify-content: space-between; }
  }
</style>
