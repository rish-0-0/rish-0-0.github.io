---
import Base from './Base.astro';
import Sidebar from '../components/Sidebar.astro';
import ThemeSwitcher from '../components/ThemeSwitcher';
import LocaleSwitcher from '../components/LocaleSwitcher';
import { t, LOCALES, DEFAULT_LOCALE } from '../i18n';
import '../styles/themes.scss';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  locale?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
}

const { title, description, locale: localeProp, ogType, publishedTime } = Astro.props;
const locale = localeProp ?? (Astro.params.locale as string | undefined) ?? 'en';
const strings = t(locale);
---

<Base title={title} description={description} lang={locale} ogType={ogType} publishedTime={publishedTime}>
  <div class="flex h-dvh overflow-hidden">
    <Sidebar locale={locale} />

    <div class="flex flex-1 flex-col overflow-hidden bg-bg">
      <header class="h-[57px] flex items-center justify-end shrink-0 px-6 gap-2 border-b border-border">
        <button
          id="menu-toggle"
          class="menu-toggle hidden items-center justify-center p-1 rounded-md border-none bg-transparent text-fg-muted hover:text-fg hover:bg-surface transition-colors"
          aria-label={strings.nav.openNavigation}
          aria-expanded="false"
          aria-controls="sidebar"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
            <path d="M3 5h14M3 10h14M3 15h14"/>
          </svg>
        </button>

        <LocaleSwitcher
          client:idle
          current={locale}
          currentPath={Astro.url.pathname}
          defaultLocale={DEFAULT_LOCALE}
          chooseLabel={strings.localeSwitcher.chooseLabel}
          currentTemplate={strings.localeSwitcher.currentTemplate}
          locales={[
            { code: 'en', label: 'English',    nativeLabel: 'English' },
            { code: 'hi', label: 'Hindi',      nativeLabel: 'हिन्दी' },
            { code: 'es', label: 'Spanish',    nativeLabel: 'Español' },
            { code: 'fr', label: 'French',     nativeLabel: 'Français' },
            { code: 'de', label: 'German',     nativeLabel: 'Deutsch' },
            { code: 'nl', label: 'Dutch',      nativeLabel: 'Nederlands' },
          ]}
        />

        <ThemeSwitcher
          client:idle
          strings={{
            chooseLabel: strings.theme.chooseLabel,
            currentTemplate: strings.theme.currentTemplate,
            themes: {
              dark: strings.theme.dark,
              light: strings.theme.light,
              solarized: strings.theme.solarized,
              aderberry: strings.theme.aderberry,
            },
          }}
        />
      </header>

      <main class="flex-1 overflow-y-auto" id="main-content" tabindex="-1">
        <slot />
      </main>
    </div>
  </div>
</Base>

<style>
  @media (max-width: 768px) {
    .menu-toggle { display: flex; }
    header { justify-content: space-between; }
  }
</style>
