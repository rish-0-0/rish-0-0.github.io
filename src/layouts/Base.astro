---
import { Font } from 'astro:assets';
import { getAbsoluteLocaleUrl } from 'astro:i18n';
import { LOCALES, DEFAULT_LOCALE } from '../i18n';
import { SITE } from '../site';

export interface Props {
  title?: string;
  description?: string;
  /** Locale of the current page (e.g. 'en', 'hi'). */
  lang?: string;
  /** Open Graph type. 'article' for blog posts / work entries. */
  ogType?: 'website' | 'article';
  /** ISO date — articles only. Emits og:article:published_time + JSON-LD. */
  publishedTime?: string;
  /** Per-page social image (absolute path or URL); falls back to SITE.ogImage. */
  ogImage?: string | null;
}

const {
  title = SITE.name,
  description = 'Personal portfolio - work, writing, and more.',
  lang = DEFAULT_LOCALE,
  ogType = 'website',
  publishedTime,
  ogImage = SITE.ogImage,
} = Astro.props;

// Full <title>: avoid "Name · Name" on the homepage.
const pageTitle = title === SITE.name ? title : `${title} · ${SITE.name}`;

// BCP-47 / OG locale codes for the configured locales.
const OG_LOCALE: Record<string, string> = {
  en: 'en_US', hi: 'hi_IN', es: 'es_ES', fr: 'fr_FR', de: 'de_DE', nl: 'nl_NL',
};

// Logical path = current path with the locale prefix removed, so we can map it
// across every locale for canonical + hreflang. Non-default locales are served
// under /{locale}/...; the default locale lives at the root (no prefix).
let logicalPath = Astro.url.pathname;
if (lang !== DEFAULT_LOCALE) {
  logicalPath = logicalPath.replace(new RegExp(`^/${lang}(?=/|$)`), '') || '/';
}

const canonical = getAbsoluteLocaleUrl(lang, logicalPath);
const alternates = LOCALES.map((loc) => ({
  hreflang: loc,
  href: getAbsoluteLocaleUrl(loc, logicalPath),
}));
const xDefault = getAbsoluteLocaleUrl(DEFAULT_LOCALE, logicalPath);

const ogImageUrl = ogImage ? new URL(ogImage, SITE.url).href : null;

// JSON-LD structured data: Person on the homepage, Article on posts/work.
const isHome = logicalPath === '/';
const jsonLd = ogType === 'article'
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      inLanguage: lang,
      datePublished: publishedTime,
      author: { '@type': 'Person', name: SITE.author },
      mainEntityOfPage: canonical,
      ...(ogImageUrl ? { image: ogImageUrl } : {}),
    }
  : isHome
    ? {
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: SITE.author,
        url: SITE.url,
      }
    : null;
---

<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0a0a0a" />

    <!-- hreflang alternates for the localised routes -->
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefault} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={OG_LOCALE[lang] ?? 'en_US'} />
    {LOCALES.filter((l) => l !== lang).map((l) => (
      <meta property="og:locale:alternate" content={OG_LOCALE[l] ?? l} />
    ))}
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}

    <!-- Twitter / X card -->
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    {SITE.twitter && <meta name="twitter:site" content={`@${SITE.twitter}`} />}

    <!-- Self-hosted, build-optimised webfonts -->
    <Font cssVariable="--font-space-grotesk" preload />
    <Font cssVariable="--font-archivo" />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- FOUC prevention: set theme before first paint, synchronously. -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('portfolio-theme');
        var valid = ['dark', 'light', 'solarized', 'aderberry'];
        if (saved && valid.indexOf(saved) !== -1)
          document.documentElement.setAttribute('data-theme', saved);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
